# --- Vite (frontend) — copy to .env.local or .env ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key

# GoCardless OAuth (browser). Redirect URI must match GoCardless app + gocardless-oauth function.
VITE_GOCARDLESS_CLIENT_ID=
VITE_GOCARDLESS_REDIRECT_URI=http://localhost:8080/oauth/callback

# Optional: sandbox (default) vs live OAuth host
# VITE_GOCARDLESS_ENV=sandbox
# VITE_GOCARDLESS_ENV=live

# Optional: override OAuth authorize host (defaults from VITE_GOCARDLESS_ENV)
# VITE_GOCARDLESS_OAUTH_BASE=https://connect-sandbox.gocardless.com

# --- Supabase Edge Functions (set in Supabase project secrets / dashboard) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# GoCardless server-side (token exchange + API calls). Must match app environment (sandbox vs live).
# GOCARDLESS_CLIENT_ID=
# GOCARDLESS_CLIENT_SECRET=
# GOCARDLESS_REDIRECT_URI=http://localhost:8080/oauth/callback

# API root (defaults to sandbox if unset). Live: https://api.gocardless.com
# GOCARDLESS_API_URL=https://api-sandbox.gocardless.com

# Stripe (browser + edge functions). Financial Connections ACH uses the publishable key in the app
# and the secret key only in Supabase Edge Function secrets (never in Vite env).
VITE_STRIPE_PUBLISHABLE_KEY=

# Set in Supabase Dashboard → Edge Functions → Secrets (not in Vite):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Tooling ---
# Install Node.js 20+ so `npm` / `npx` are on your PATH (Vite, Vitest, Playwright).
# Or open the repo in a Dev Container (see .devcontainer/devcontainer.json) for npm + Playwright preinstalled.
