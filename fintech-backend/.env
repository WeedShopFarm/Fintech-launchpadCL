NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autocollect
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=autocollect
DATABASE_POOL_SIZE=20
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT
JWT_SECRET=dev-super-secret-jwt-key-min-32-characters-longxxxxx
JWT_REFRESH_SECRET=dev-super-secret-refresh-key-min-32-charsxxxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (Sandbox)
STRIPE_SECRET_KEY=sk_test_51234567890abcdefghijklmnopqrstu
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnopqrstu
STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdefghijklmnopqrstu
STRIPE_API_VERSION=2024-04-10

# Yapily (Sandbox)
YAPILY_APPLICATION_ID=app-id-sandbox-123456
YAPILY_SECRET_KEY=secret-key-sandbox-123456
YAPILY_ENVIRONMENT=sandbox
YAPILY_CALLBACK_URL=http://localhost:3000/api/webhooks/yapily
YAPILY_API_VERSION=v2.3

# GoCardless (Sandbox)
GOCARDLESS_ACCESS_TOKEN=sandbox_token_123456789
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_WEBHOOK_SECRET=wh_secret_sandbox_123456
GOCARDLESS_CREDITOR_ID=CR0000000000001

# Wise
WISE_API_KEY=sandbox-api-key-123456
WISE_PROFILE_ID=profile-id-123456

# Encryption
ENCRYPTION_KEY=dev-32-character-encryption-key-1234567890ab

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Cors
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# API Keys
API_KEY_HEADER=X-API-Key
