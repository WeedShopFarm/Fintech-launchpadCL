NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/autocollect
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=autocollect
DATABASE_POOL_SIZE=20
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=true

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_API_VERSION=2024-04-10

# Yapily
YAPILY_APPLICATION_ID=your-app-id
YAPILY_SECRET_KEY=your-secret-key
YAPILY_ENVIRONMENT=sandbox
YAPILY_CALLBACK_URL=http://localhost:3000/api/webhooks/yapily
YAPILY_API_VERSION=v2.3

# GoCardless
GOCARDLESS_ACCESS_TOKEN=your-access-token
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_WEBHOOK_SECRET=your-webhook-secret
GOCARDLESS_CREDITOR_ID=CR123456789

# Wise
WISE_API_KEY=your-wise-api-key
WISE_PROFILE_ID=your-profile-id

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-1234567890ab

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Cors
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# API Keys
API_KEY_HEADER=X-API-Key